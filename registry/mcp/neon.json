{
  "id": "neon",
  "type": "mcp",
  "name": "Neon",
  "description": "Neon's official MCP server: manage serverless Postgres databases, branches, and queries.",
  "author": "Neon",
  "tags": [
    "database",
    "postgres",
    "serverless"
  ],
  "source": {
    "repo": "neondatabase/mcp-server-neon",
    "path": "."
  },
  "mcp": {
    "type": "stdio",
    "command": "npx",
    "args": [
      "-y",
      "@neondatabase/mcp-server-neon",
      "start",
      "${NEON_API_KEY}"
    ]
  }
}
