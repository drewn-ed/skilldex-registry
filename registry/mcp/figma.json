{
  "id": "figma",
  "type": "mcp",
  "name": "Figma Context",
  "description": "Framelink's Figma MCP server: give Claude your Figma designs for accurate design-to-code.",
  "author": "Framelink",
  "tags": [
    "figma",
    "design",
    "frontend"
  ],
  "source": {
    "repo": "GLips/Figma-Context-MCP",
    "path": "."
  },
  "mcp": {
    "type": "stdio",
    "command": "npx",
    "args": [
      "-y",
      "figma-developer-mcp",
      "--stdio"
    ],
    "env": {
      "FIGMA_API_KEY": "${FIGMA_API_KEY}"
    }
  }
}
