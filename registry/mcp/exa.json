{
  "id": "exa",
  "type": "mcp",
  "name": "Exa Search",
  "description": "Exa's official MCP server: AI-native web search, company research, and content crawling.",
  "author": "Exa",
  "tags": [
    "search",
    "web",
    "research"
  ],
  "source": {
    "repo": "exa-labs/exa-mcp-server",
    "path": "."
  },
  "mcp": {
    "type": "stdio",
    "command": "npx",
    "args": [
      "-y",
      "exa-mcp-server"
    ],
    "env": {
      "EXA_API_KEY": "${EXA_API_KEY}"
    }
  }
}
