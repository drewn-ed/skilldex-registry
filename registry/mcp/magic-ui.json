{
  "id": "magic-ui",
  "type": "mcp",
  "name": "21st.dev Magic",
  "description": "21st.dev's Magic MCP server: generate polished UI components from natural language.",
  "author": "21st.dev",
  "tags": [
    "ui",
    "components",
    "frontend"
  ],
  "source": {
    "repo": "21st-dev/magic-mcp",
    "path": "."
  },
  "mcp": {
    "type": "stdio",
    "command": "npx",
    "args": [
      "-y",
      "@21st-dev/magic"
    ],
    "env": {
      "API_KEY": "${TWENTYFIRST_API_KEY}"
    }
  }
}
